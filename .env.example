# Example environment variables for local development
# Copy this to .env and update with your values
# DO NOT commit .env to git (it's in .gitignore)

# Server
PORT=8080

# AI Configuration (Phase 9C, 9D)
# AI explanations are disabled by default for safety and simplicity
ENABLE_AI_EXPLANATIONS=false

# AI provider selection
# Options: "none" (disabled), "vertex-gemini" (Phase 9D), "openai" (future)
AI_PROVIDER=none

# AI model name (ignored when AI_PROVIDER=none)
# For Gemini: gemini-2.5-flash, gemini-2.0-pro, etc.
AI_MODEL=gemini-2.5-flash

# Google Cloud configuration (required only if using Vertex AI provider)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=europe-west2

# Gemini API configuration (required only if using vertex-gemini provider)
# DO NOT commit your real API key to version control
# Use Google Cloud Secret Manager or environment variable injection instead
# GOOGLE_API_KEY=your-gemini-api-key-here
# GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI configuration (required only if using OpenAI provider)
# DO NOT commit your real API key to version control
# Use Google Cloud Secret Manager or environment variable injection instead
# OPENAI_API_KEY=sk-your-api-key-here
